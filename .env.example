# Production authentication (never commit real values)
INVITE_HMAC_SECRET=replace-with-at-least-32-random-bytes
SESSION_SECRET=replace-with-a-different-32-byte-random-value
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD_HASH=pbkdf2_sha256$600000$replace-salt$replace-digest
ACCESS_SESSION_DAYS=30
AUTH_COOKIE_SECURE=true
REQUIRE_INVITE_AUTH=true
REQUIRE_PERSISTENT_DATABASE=true
TAIL_STOCK_DATABASE=/persistent-volume/scan_history.db
PWA_PUBLIC_URL=https://your-pwa.example.com
PWA_ALLOWED_ORIGINS=https://your-pwa.example.com
